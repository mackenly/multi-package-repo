{
  "name": "multi-package-repo",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "frontend",
    "backend",
    "micro-service",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "docker compose up --build -d",
    "down": "docker compose down --remove-orphans"
  },
  "devDependencies": {
    "typescript": "5.4.5"
  }
}
