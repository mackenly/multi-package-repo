{
  "name": "multi-package-repo",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "multi-package-repo",
      "workspaces": [
        "frontend",
        "backend",
        "micro-service",
        "packages/*"
      ],
      "devDependencies": {
        "typescript": "5.4.5"
      }
    },
    "backend": {
      "name": "@projectname/backend",
      "version": "0.0.0",
      "dependencies": {
        "@projectname/app-types": "file:../packages/app-types",
        "@projectname/auth": "file:../packages/auth",
        "@projectname/utils": "file:../packages/utils"
      }
    },
    "frontend": {
      "name": "@projectname/frontend",
      "version": "0.0.0",
      "dependencies": {
        "@projectname/app-types": "file:../packages/app-types",
        "@projectname/auth": "file:../packages/auth",
        "@projectname/utils": "file:../packages/utils"
      }
    },
    "micro-service": {
      "name": "@projectname/micro-service",
      "version": "0.0.0",
      "dependencies": {
        "@projectname/app-types": "file:../packages/app-types",
        "@projectname/auth": "file:../packages/auth",
        "@projectname/utils": "file:../packages/utils"
      }
    },
    "node_modules/@projectname/app-types": {
      "resolved": "packages/app-types",
      "link": true
    },
    "node_modules/@projectname/auth": {
      "resolved": "packages/auth",
      "link": true
    },
    "node_modules/@projectname/backend": {
      "resolved": "backend",
      "link": true
    },
    "node_modules/@projectname/frontend": {
      "resolved": "frontend",
      "link": true
    },
    "node_modules/@projectname/micro-service": {
      "resolved": "micro-service",
      "link": true
    },
    "node_modules/@projectname/utils": {
      "resolved": "packages/utils",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.4.5",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/app-types": {
      "name": "@projectname/app-types",
      "version": "0.0.0",
      "devDependencies": {
        "typescript": "5.4.5"
      }
    },
    "packages/auth": {
      "name": "@projectname/auth",
      "version": "0.0.0",
      "dependencies": {
        "@projectname/app-types": "file:../app-types"
      },
      "devDependencies": {
        "typescript": "5.4.5"
      }
    },
    "packages/utils": {
      "name": "@projectname/utils",
      "version": "0.0.0",
      "dependencies": {
        "@projectname/app-types": "file:../app-types"
      },
      "devDependencies": {
        "typescript": "5.4.5"
      }
    }
  }
}
